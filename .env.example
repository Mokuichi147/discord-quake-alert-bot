# Discord の Webhook URL（必須）
# サーバー設定 → 連携サービス → ウェブフック で発行
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# 通知のしきい値（任意・スケール値で指定）
#   10=震度1 20=2 30=3 40=4 45=5弱 50=5強 55=6弱 60=6強 70=7
# 地震情報(551)の観測震度・緊急地震速報(556)の予想震度の両方に適用されます。
# 関東で通知する最小震度（既定 40 = 震度4）
KANTO_MIN_SCALE=40
# 関東以外で通知する最小震度（既定 50 = 震度5強）
OTHER_MIN_SCALE=50

# 地図画像を添付するか（true/false、既定 true）
ATTACH_MAP=true

# 地図タイルの URL テンプレート（任意）
# 既定は国土地理院の白地図(blank、日本全国・zoom 5〜14)。
# 利用時は出典「地理院タイル」の表示が必要です（本botは通知に出典を明記します）。
#   https://maps.gsi.go.jp/development/ichiran.html
# OpenStreetMap に戻す場合は次を指定: https://tile.openstreetmap.org/{z}/{x}/{y}.png
TILE_URL_TEMPLATE=https://cyberjapandata.gsi.go.jp/xyz/blank/{z}/{x}/{y}.png

# WebSocket エンドポイント（任意・通常変更不要）
P2PQUAKE_WS_URL=wss://api.p2pquake.net/v2/ws

# ログレベル（任意）
RUST_LOG=info
